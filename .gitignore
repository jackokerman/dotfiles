.DS_Store
.vscode

# Local overrides (machine-specific, not tracked)
*.local
*.local.*
!.local/

# Temporary files generated by scripts
tmp/

# Local tuicr theme experiments
home/.config/tuicr/config.toml.before-tuicr-teal-test
home/.config/tuicr/themes/tuicr-teal.toml
home/.config/tuicr/themes/tuicr-teal-syntax.tmTheme

# Claude: ignore everything in the tracked source tree except the allowlisted
# entries that `setup_claude` manages into the live `~/.claude/` directory.
home/.claude/*
!home/.claude/CLAUDE.md
!home/.claude/settings.json
!home/.claude/hooks/
!home/.claude/hooks/**
!home/.claude/rules/
!home/.claude/rules/**
!home/.claude/skills/
!home/.claude/skills/**
