.DS_Store
.vscode

# Local overrides (machine-specific, not tracked)
*.local
*.local.*
!.local/

# Temporary files generated by scripts
tmp/

# Claude runtime state belongs in the live `~/.claude` directory, not the
# tracked source tree under `home/.claude/`.
home/.claude/backups/
home/.claude/cache/
home/.claude/file-history/
home/.claude/history.jsonl
home/.claude/mcp-needs-auth-cache.json
home/.claude/plugins/
home/.claude/projects/
home/.claude/session-env/
home/.claude/sessions/
home/.claude/shell-snapshots/
