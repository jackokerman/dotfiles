{
  "model": "claude-opus-4-6",
  "alwaysThinkingEnabled": true,
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/tmux/agent-status-hook.sh working"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/validate-conventional-commits.sh",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/tmux/agent-status-hook.sh working"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/tmux/agent-status-hook.sh done"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt|elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/tmux/agent-status-hook.sh waiting"
          }
        ]
      }
    ],
    "ElicitationResult": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/tmux/agent-status-hook.sh working"
          }
        ]
      }
    ]
  },
  "enableAllProjectMcpServers": true,
  "skipDangerousModePermissionPrompt": true,
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "defaultMode": "bypassPermissions",
    "additionalDirectories": [
      "/Users/jackokerman/.claude",
      "/Users/jackokerman/dotfiles"
    ],
    "allow": [
      "Read(/Users/jackokerman/**)",
      "Read(/tmp/**)",
      "Write(/tmp/**)",

      "Edit(/Users/jackokerman/dotfiles/**)",
      "Edit(/Users/jackokerman/.claude/**)",
      "Write(/Users/jackokerman/dotfiles/**)",
      "Write(/Users/jackokerman/.claude/**)",

      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(dotty:*)",

      "Bash(cat:*)",
      "Bash(echo:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(ls:*)",
      "Bash(test:*)",
      "Bash(tree:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(diff:*)",
      "Bash(readlink:*)",
      "Bash(realpath:*)",
      "Bash(dirname:*)",
      "Bash(basename:*)",
      "Bash(which:*)",
      "Bash(stat:*)",
      "Bash(file:*)",
      "Bash(xargs:*)",
      "Bash(pwd:*)",
      "Bash(shellcheck:*)",
      "Bash(zsh -n:*)",

      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:github.com)",
      "WebSearch"
    ]
  }
}
