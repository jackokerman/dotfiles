#!/usr/bin/env bash

set -euo pipefail

usage() {
    cat <<'EOF'
Usage: public-content-guard [--staged|--worktree] [--patterns-file PATH] [--exclude PATH] [PATH...]

Blocks added public-repo lines that match configured sensitive-content patterns.

Pattern sources:
  - repo .githooks/sensitive-content-patterns when present
  - $XDG_CONFIG_HOME/public-content-guard/patterns when present
  - colon-separated $PUBLIC_CONTENT_GUARD_PATTERN_FILE paths
  - newline-separated $PUBLIC_CONTENT_GUARD_PATTERNS entries

Set PUBLIC_CONTENT_GUARD_SKIP=1 to disable the guard.
EOF
}

die() {
    printf 'public-content-guard: %s\n' "$*" >&2
    exit 1
}

trim() {
    local value="$1"
    value="${value#"${value%%[![:space:]]*}"}"
    value="${value%"${value##*[![:space:]]}"}"
    printf '%s' "$value"
}

append_pattern() {
    local pattern
    pattern="$(trim "$1")"
    [[ -z "$pattern" || "$pattern" == \#* ]] && return
    PATTERNS+=("$pattern")
}

load_patterns_file() {
    local path="$1"
    local line

    [[ -f "$path" ]] || return 0
    while IFS= read -r line || [[ -n "$line" ]]; do
        append_pattern "$line"
    done < "$path"
}

combined_patterns() {
    local pattern
    local combined=""

    for pattern in "${PATTERNS[@]+"${PATTERNS[@]}"}"; do
        [[ -n "$combined" ]] && combined+="|"
        combined+="$pattern"
    done

    printf '%s' "$combined"
}

repo_root() {
    git rev-parse --show-toplevel 2>/dev/null || pwd
}

MODE="staged"
PATHS=()
EXCLUDES=()
PATTERN_FILES=()
PATTERNS=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        --staged)
            MODE="staged"
            ;;
        --worktree)
            MODE="worktree"
            ;;
        --patterns-file)
            [[ $# -ge 2 ]] || die "--patterns-file requires a path"
            PATTERN_FILES+=("$2")
            shift
            ;;
        --exclude)
            [[ $# -ge 2 ]] || die "--exclude requires a path"
            EXCLUDES+=("$2")
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        --)
            shift
            while [[ $# -gt 0 ]]; do
                PATHS+=("$1")
                shift
            done
            break
            ;;
        -*)
            die "unknown argument: $1"
            ;;
        *)
            PATHS+=("$1")
            ;;
    esac
    shift
done

[[ "${PUBLIC_CONTENT_GUARD_SKIP:-0}" == "1" ]] && exit 0

REPO_ROOT="$(repo_root)"

DEFAULT_REPO_PATTERNS="$REPO_ROOT/.githooks/sensitive-content-patterns"
DEFAULT_USER_PATTERNS="${XDG_CONFIG_HOME:-$HOME/.config}/public-content-guard/patterns"

PATTERN_FILES=("$DEFAULT_REPO_PATTERNS" "$DEFAULT_USER_PATTERNS" "${PATTERN_FILES[@]+"${PATTERN_FILES[@]}"}")

if [[ -n "${PUBLIC_CONTENT_GUARD_PATTERN_FILE:-}" ]]; then
    IFS=':' read -r -a ENV_PATTERN_FILES <<< "$PUBLIC_CONTENT_GUARD_PATTERN_FILE"
    PATTERN_FILES+=("${ENV_PATTERN_FILES[@]}")
fi

for pattern_file in "${PATTERN_FILES[@]+"${PATTERN_FILES[@]}"}"; do
    load_patterns_file "$pattern_file"
done

if [[ -n "${PUBLIC_CONTENT_GUARD_PATTERNS:-}" ]]; then
    while IFS= read -r pattern || [[ -n "$pattern" ]]; do
        append_pattern "$pattern"
    done <<< "$PUBLIC_CONTENT_GUARD_PATTERNS"
fi

COMBINED="$(combined_patterns)"
[[ -n "$COMBINED" ]] || exit 0

GIT_PATHS=()
if [[ ${#PATHS[@]} -gt 0 ]]; then
    GIT_PATHS+=("--" "${PATHS[@]}")
else
    GIT_PATHS+=("--" ".")
fi

if [[ ${#EXCLUDES[@]} -gt 0 ]]; then
    for excluded in "${EXCLUDES[@]}"; do
        GIT_PATHS+=(":(exclude)$excluded")
    done
fi

matches=""

case "$MODE" in
    staged)
        staged_files="$(git -C "$REPO_ROOT" diff --cached --name-only --diff-filter=ACMR "${GIT_PATHS[@]}")"
        [[ -n "$staged_files" ]] || exit 0

        while IFS= read -r file; do
            [[ -n "$file" ]] || continue

            file_matches="$(git -C "$REPO_ROOT" diff --cached --unified=0 --no-color -- "$file" | grep -iE "^\+[^+].*($COMBINED)" || true)"
            [[ -n "$file_matches" ]] || continue

            while IFS= read -r line; do
                [[ -n "$line" ]] || continue
                matches+="$file: $line"$'\n'
            done <<< "$file_matches"
        done <<< "$staged_files"
        ;;
    worktree)
        tracked_files="$(git -C "$REPO_ROOT" ls-files "${GIT_PATHS[@]}")"
        [[ -n "$tracked_files" ]] || exit 0

        while IFS= read -r file; do
            [[ -n "$file" && -f "$REPO_ROOT/$file" ]] || continue

            file_matches="$(grep -iEn "$COMBINED" "$REPO_ROOT/$file" || true)"
            [[ -n "$file_matches" ]] || continue

            while IFS= read -r line; do
                [[ -n "$line" ]] || continue
                matches+="$file: $line"$'\n'
            done <<< "$file_matches"
        done <<< "$tracked_files"
        ;;
    *)
        die "unknown mode: $MODE"
        ;;
esac

if [[ -n "$matches" ]]; then
    printf '\n'
    printf '  Commit blocked. Added lines contain content this public repo should not mention.\n'
    printf '\n'
    printf '  Matches found:\n'
    printf '\n'
    printf '%s' "$matches" | head -20 | while IFS= read -r line; do
        printf '    %s\n' "$line"
    done

    local_count="$(printf '%s' "$matches" | wc -l | tr -d ' ')"
    if [[ "$local_count" -gt 20 ]]; then
        printf '    ... and %s more\n' "$((local_count - 20))"
    fi

    printf '\n'
    printf '  Remove or reword the added text, or bypass the guard if this is intentional.\n'
    printf '\n'
    exit 1
fi
