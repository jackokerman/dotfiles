#!/usr/bin/env bash

set -euo pipefail

url="${1:-https://example.com}"
label="${2:-Ghostty tmux hyperlink test}"

printf 'OSC 8 hyperlink: \e]8;;%s\a%s\e]8;;\a\n' "$url" "$label"
printf 'Plain URL: %s\n' "$url"
printf '\nUse Shift+Cmd+Click on the OSC 8 line in Ghostty inside tmux on macOS.\n'
printf 'Plain click is still handled by tmux mouse mode; older Cmd+Click guidance was wrong for this setup.\n'
printf 'If the OSC 8 line opens, tmux hyperlink passthrough is working. If an agent link still does not, investigate that program output.\n'
