#!/usr/bin/env bash
# Save and restore Chrome window workspace assignments across restarts.
set -euo pipefail

readonly STATE_DIR="$HOME/.local/state/chrome-workspaces"
readonly STATE_FILE="${STATE_DIR}/state.json"

die() {
  printf '%s\n' "$1" >&2
  exit 1
}

_get_chrome_app_names() {
  local -A names
  names["Google Chrome"]=1
  local app_dir="$HOME/Applications/Chrome Apps.localized"
  if [[ -d "${app_dir}" ]]; then
    local app app_basename
    for app in "${app_dir}"/*.app; do
      [[ -e "${app}" ]] || continue
      app_basename="$(basename "${app}" .app)"
      names["${app_basename}"]=1
    done
  fi
  printf '%s\n' "${!names[@]}"
}

_get_chrome_windows() {
  local -A chrome_apps
  local name
  while IFS= read -r name; do
    chrome_apps["${name}"]=1
  done < <(_get_chrome_app_names)

  while IFS='|' read -r wid app_name workspace title; do
    if [[ -n "${chrome_apps["${app_name}"]:-}" ]]; then
      printf '%s|%s|%s|%s\n' "${wid}" "${workspace}" "${app_name}" "${title}"
    fi
  done < <(aerospace list-windows --all --format '%{window-id}|%{app-name}|%{workspace}|%{window-title}')
}

_extract_profile() {
  local title="$1"
  if [[ "${title}" == *" - Google Chrome - "* ]]; then
    printf '%s' "${title##* - Google Chrome - }"
  else
    printf ''
  fi
}

_extract_tab_title() {
  local title="$1"
  if [[ "${title}" == *" - Google Chrome"* ]]; then
    printf '%s' "${title%% - Google Chrome*}"
  else
    printf '%s' "${title}"
  fi
}

_word_overlap() {
  local a="$1" b="$2"
  local -i count=0
  local word
  for word in ${a}; do
    if [[ "${b}" == *"${word}"* && ${#word} -gt 2 ]]; then
      (( ++count ))
    fi
  done
  printf '%d' "${count}"
}

cmd_save() {
  local windows
  windows=$(_get_chrome_windows)

  if [[ -z "${windows}" ]]; then
    die "No Chrome windows found"
  fi

  mkdir -p "${STATE_DIR}"

  local json_windows=()
  local -i count=0
  local -A workspaces_seen
  local profile

  while IFS='|' read -r wid workspace app_name title; do
    profile=$(_extract_profile "${title}")
    json_windows+=("$(jq -n \
      --arg ws "${workspace}" \
      --arg an "${app_name}" \
      --arg t "${title}" \
      --arg p "${profile}" \
      '{workspace: $ws, app_name: $an, title: $t, profile: $p}')")
    workspaces_seen["${workspace}"]=1
    (( ++count ))
  done <<< "${windows}"

  local joined
  joined=$(printf '%s\n' "${json_windows[@]}" | jq -s '.')

  jq -n \
    --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    --argjson wins "${joined}" \
    '{saved_at: $ts, windows: $wins}' > "${STATE_FILE}"

  local ws_list
  ws_list=$(printf '%s\n' "${!workspaces_seen[@]}" | sort | tr '\n' ' ')
  printf 'Saved %d Chrome windows across workspaces: %s\n' "${count}" "${ws_list% }"
}

cmd_restore() {
  if [[ ! -f "${STATE_FILE}" ]]; then
    die "No saved state found. Run 'chrome-workspaces save' first."
  fi

  local current_windows
  current_windows=$(_get_chrome_windows)

  if [[ -z "${current_windows}" ]]; then
    die "No Chrome windows found"
  fi

  local saved_at
  saved_at=$(jq -r '.saved_at' "${STATE_FILE}")
  local -a sav_workspaces=() sav_app_names=() sav_titles=() sav_profiles=()
  while IFS=$'\t' read -r ws an title prof; do
    sav_workspaces+=("${ws}")
    sav_app_names+=("${an}")
    sav_titles+=("${title}")
    sav_profiles+=("${prof}")
  done < <(jq -r '.windows[] | [.workspace, (.app_name // "Google Chrome"), .title, .profile] | @tsv' "${STATE_FILE}")
  local -i saved_count=${#sav_workspaces[@]}

  local -i moved=0 already=0 unmatched_saved=0

  local -a cur_ids=() cur_workspaces=() cur_app_names=() cur_titles=()
  while IFS='|' read -r wid workspace app_name title; do
    cur_ids+=("${wid}")
    cur_workspaces+=("${workspace}")
    cur_app_names+=("${app_name}")
    cur_titles+=("${title}")
  done <<< "${current_windows}"

  local -A matched_current matched_saved
  local cur_profile cur_tab_title saved_tab_title
  local -i i j best_j best_overlap overlap

  _move_or_count() {
    local -i ci=$1
    local target_ws="$2"
    matched_current[${ci}]=1
    if [[ "${cur_workspaces[${ci}]}" == "${target_ws}" ]]; then
      (( ++already ))
    else
      aerospace move-node-to-workspace "${target_ws}" --window-id "${cur_ids[${ci}]}" 2>/dev/null || true
      (( ++moved ))
    fi
  }

  # PWA pass: match non-Chrome apps by exact app_name
  for (( i = 0; i < saved_count; i++ )); do
    if [[ "${sav_app_names[${i}]}" == "Google Chrome" ]]; then
      continue
    fi
    for (( j = 0; j < ${#cur_ids[@]}; j++ )); do
      if [[ -z "${matched_current[${j}]:-}" && "${cur_app_names[${j}]}" == "${sav_app_names[${i}]}" ]]; then
        matched_saved[${i}]=1
        _move_or_count "${j}" "${sav_workspaces[${i}]}"
        break
      fi
    done
  done

  # Pass 1: exact title match (Chrome browser windows only)
  for (( i = 0; i < saved_count; i++ )); do
    if [[ -n "${matched_saved[${i}]:-}" ]]; then
      continue
    fi
    for (( j = 0; j < ${#cur_ids[@]}; j++ )); do
      if [[ -z "${matched_current[${j}]:-}" && "${cur_app_names[${j}]}" == "Google Chrome" && "${cur_titles[${j}]}" == "${sav_titles[${i}]}" ]]; then
        matched_saved[${i}]=1
        _move_or_count "${j}" "${sav_workspaces[${i}]}"
        break
      fi
    done
  done

  # Pass 2: same-profile word overlap for unmatched Chrome windows
  for (( i = 0; i < saved_count; i++ )); do
    if [[ -n "${matched_saved[${i}]:-}" ]]; then
      continue
    fi

    saved_tab_title=$(_extract_tab_title "${sav_titles[${i}]}")
    best_j=-1
    best_overlap=0

    for (( j = 0; j < ${#cur_ids[@]}; j++ )); do
      if [[ -n "${matched_current[${j}]:-}" || "${cur_app_names[${j}]}" != "Google Chrome" ]]; then
        continue
      fi
      cur_profile=$(_extract_profile "${cur_titles[${j}]}")
      if [[ "${cur_profile}" != "${sav_profiles[${i}]}" ]]; then
        continue
      fi
      cur_tab_title=$(_extract_tab_title "${cur_titles[${j}]}")
      overlap=$(_word_overlap "${saved_tab_title}" "${cur_tab_title}")
      if (( overlap > best_overlap )); then
        best_overlap=${overlap}
        best_j=${j}
      fi
    done

    if (( best_j >= 0 )); then
      matched_saved[${i}]=1
      _move_or_count "${best_j}" "${sav_workspaces[${i}]}"
    fi
  done

  # Pass 3: pair remaining unmatched Chrome windows by profile
  for (( i = 0; i < saved_count; i++ )); do
    if [[ -n "${matched_saved[${i}]:-}" ]]; then
      continue
    fi
    for (( j = 0; j < ${#cur_ids[@]}; j++ )); do
      if [[ -n "${matched_current[${j}]:-}" || "${cur_app_names[${j}]}" != "Google Chrome" ]]; then
        continue
      fi
      cur_profile=$(_extract_profile "${cur_titles[${j}]}")
      if [[ "${cur_profile}" == "${sav_profiles[${i}]}" ]]; then
        matched_saved[${i}]=1
        _move_or_count "${j}" "${sav_workspaces[${i}]}"
        break
      fi
    done
    if [[ -z "${matched_saved[${i}]:-}" ]]; then
      (( ++unmatched_saved ))
    fi
  done

  printf 'Restored from %s: %d moved, %d already correct' "${saved_at}" "${moved}" "${already}"
  if (( unmatched_saved > 0 )); then
    printf ', %d unmatched' "${unmatched_saved}"
  fi
  printf '\n'
}

cmd_restart() {
  local original_workspace
  original_workspace=$(aerospace list-workspaces --focused)

  local -i expected
  expected=$(_get_chrome_windows | wc -l)
  if (( expected == 0 )); then
    die "No Chrome windows found"
  fi

  # Capture old window IDs so we can detect when they're gone
  local old_ids
  old_ids=$(_get_chrome_windows | cut -d'|' -f1 | sort)

  cmd_save

  printf 'Restarting Chrome...\n'
  osascript -e 'tell application "Google Chrome" to open location "chrome://restart"'

  # Wait for old windows to disappear (chrome://restart may not kill the process)
  local -i timeout=90 elapsed=0
  while (( elapsed < timeout )); do
    local cur_ids
    cur_ids=$(_get_chrome_windows | cut -d'|' -f1 | sort)
    if [[ "${cur_ids}" != "${old_ids}" ]]; then
      break
    fi
    sleep 0.5
    (( ++elapsed ))
  done
  printf 'Old windows gone, waiting for new windows...\n'

  # Wait for expected number of windows to reappear
  local -i current=0
  while (( elapsed < timeout )); do
    current=$(_get_chrome_windows | wc -l)
    if (( current >= expected )); then
      break
    fi
    printf '  %d/%d windows...\n' "${current}" "${expected}"
    sleep 1
    (( ++elapsed ))
  done

  if (( elapsed >= timeout )); then
    printf 'Timed out waiting for windows (got %d of %d), restoring anyway\n' "${current}" "${expected}" >&2
  else
    printf 'All %d windows found, waiting for titles to load...\n' "${current}"
  fi

  # Wait for window titles to stabilize (Chrome loads tabs progressively)
  local prev_titles="" cur_titles=""
  local -i stable=0
  while (( elapsed < timeout && stable < 2 )); do
    cur_titles=$(_get_chrome_windows | cut -d'|' -f3- | sort)
    if [[ "${cur_titles}" == "${prev_titles}" ]]; then
      (( ++stable ))
    else
      stable=0
    fi
    prev_titles="${cur_titles}"
    sleep 1
    (( ++elapsed ))
  done
  printf 'Titles stable, restoring workspaces...\n'

  cmd_restore

  aerospace workspace "${original_workspace}" 2>/dev/null || true
}

case "${1:-}" in
  save) cmd_save ;;
  restore) cmd_restore ;;
  restart) cmd_restart ;;
  *) die "Usage: chrome-workspaces {save|restore|restart}" ;;
esac
