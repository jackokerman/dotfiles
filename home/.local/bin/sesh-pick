#!/usr/bin/env bash
# Extensible sesh session picker.
# Extension points:
#   ~/.cache/sesh-extra-entries     — extra fzf entries (one per line)
#   ~/.config/sesh/hooks/refresh.d/ — background cache refresh scripts (run each open)
#   ~/.config/sesh/hooks/connect.d/ — selection routing hooks (exit 0 = handled)

set -euo pipefail

EXTRA="${XDG_CACHE_HOME:-$HOME/.cache}/sesh-extra-entries"
HOOKS_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/sesh/hooks/connect.d"
REFRESH_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/sesh/hooks/refresh.d"

run_refresh_hooks() {
  local mode="$1"
  local hook

  [[ -d "$REFRESH_DIR" ]] || return 0

  for hook in "$REFRESH_DIR"/*; do
    [[ -x "$hook" ]] || continue

    if [[ "$mode" == "sync" ]]; then
      SESH_PICK_FORCE_REFRESH=1 "$hook" </dev/null &>/dev/null || true
    else
      # Detach hooks so they can survive tmux popup closure.
      if command -v setsid >/dev/null 2>&1; then
        setsid "$hook" </dev/null &>/dev/null &
      else
        nohup "$hook" </dev/null &>/dev/null &
      fi
    fi
  done
}

# Filter extra entries that already have a tmux session (avoids duplicates).
# Each extra entry is "icon name" — we strip the prefix and check tmux.
_extra_entries() {
  [[ -s "$EXTRA" ]] || return 0
  local tmux_sessions
  tmux_sessions=$(tmux list-sessions -F '#S' 2>/dev/null || true)
  while IFS= read -r line; do
    local name="${line#* }"
    local bare_name="${name% *}"
    if ! echo "$tmux_sessions" | grep -qxF "$name" \
      && ! echo "$tmux_sessions" | grep -qxF "$bare_name"; then
      echo "$line"
    fi
  done < "$EXTRA"
}

_tmux_entries() {
  local rows=""

  rows=$(tmux list-sessions -F $'#{session_activity}\t\033[34m\033[39m #{session_name}' 2>/dev/null || true)
  [[ -n "$rows" ]] || return 0
  printf '%s\n' "$rows" | sort -t $'\t' -k1,1nr | cut -f2-
}

_all() { _tmux_entries; _extra_entries; sesh list -ic; sesh list -iz; }

normalize_selection() {
  local label="$1" cleaned="" prefix="" rest=""

  cleaned="$(printf '%s\n' "$label" | sed $'s/\x1b\\[[0-9;]*m//g')"
  if [[ "$cleaned" != *" "* ]]; then
    printf '%s\n' "$cleaned"
    return 0
  fi

  prefix="${cleaned%% *}"
  rest="${cleaned#* }"

  case "$prefix" in
    [[:alnum:]_./~:-]*)
      printf '%s\n' "$cleaned"
      ;;
    *)
      printf '%s\n' "$rest"
      ;;
  esac
}

run_connect_hooks() {
  local session="$1"
  local hook

  [[ -d "$HOOKS_DIR" ]] || return 1

  for hook in "$HOOKS_DIR"/*; do
    [[ -x "$hook" ]] || continue

    if "$hook" --match "$session" >/dev/null 2>&1; then
      exec "$hook" "$session"
    fi

    if "$hook" "$session"; then
      return 0
    fi
  done

  return 1
}

# Sub-commands for fzf reload (fzf can't call bash functions directly)
if [[ "${1:-}" == "--all" ]]; then _all; exit 0; fi
if [[ "${1:-}" == "--tmux" ]]; then _tmux_entries; exit 0; fi
if [[ "${1:-}" == "--extra" ]]; then _extra_entries; exit 0; fi
if [[ "${1:-}" == "--refresh-all" ]]; then run_refresh_hooks sync; _all; exit 0; fi
if [[ "${1:-}" == "--refresh-extra" ]]; then run_refresh_hooks sync; _extra_entries; exit 0; fi
if [[ "${1:-}" == "--kill-selection" ]]; then
  shift
  session="$(normalize_selection "$*")"
  [[ -n "$session" ]] || exit 0
  tmux kill-session -t "$session" 2>/dev/null || true
  rm -f "${XDG_CACHE_HOME:-$HOME/.cache}/sesh/sessions.gob"
  exit 0
fi

# Kick off background refresh hooks (SWR: show stale entries now, refresh for
# the next open). Do not mutate the active fzf list; that can move the selection
# while the user is navigating it.
run_refresh_hooks async

pick_session() {
  local header="$1"
  shift

  _all | grep -v '^$' | fzf \
    --no-sort --ansi \
    --border-label=" sesh " --prompt="⚡  " \
    --header="$header" \
    --bind "tab:down,btab:up" \
    --bind "ctrl-a:change-prompt(⚡  )+reload($0 --refresh-all)" \
    --bind "ctrl-t:change-prompt(🪟  )+reload($0 --tmux)" \
    --bind "ctrl-f:change-prompt(🔎  )+reload(fd -H -d 2 -t d -E .git -E node_modules)" \
    --bind "ctrl-d:execute-silent($0 --kill-selection {})+change-prompt(⚡  )+reload($0 --all)" \
    "$@" || true
}

header="  ^a all ^t tmux ^x remote ^d kill ^f find"
selected=$(pick_session "$header" --bind "ctrl-x:change-prompt(📦  )+reload($0 --refresh-extra)")

[[ -z "$selected" ]] && exit 0
session="$(normalize_selection "$selected")"

if tmux has-session -t "$session" 2>/dev/null; then
  exec sesh connect "$session"
fi

# Try connect hooks
if run_connect_hooks "$session"; then
  exit 0
fi

# Default: sesh connect
sesh connect "$session"
