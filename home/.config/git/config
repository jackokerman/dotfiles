# Keep shared Git defaults in this tracked file.
# Use `git config-shared` or `git config --file ~/.config/git/config`.
# Avoid `git config --global` in this setup because it writes unmanaged ~/.gitconfig.

[init]
    defaultBranch = main

[include]
    # Include local git settings from ~/.gitconfig.local
    # This allows machine-specific settings (like user.name, user.email, etc.)
    # to be kept outside of version control
    path = ~/.gitconfig.local

[fetch]
    prune = true

[pull]
    rebase = true

[rebase]
    autosquash = true
    updateRefs = true

[push]
    autoSetupRemote = true

[core]
    pager = ~/.local/bin/git-pager-delta

[feature]
    manyFiles = true

[index]
    # Powerlevel10k/gitstatus uses libgit2, which doesn't support skipHash.
    # Keep manyFiles enabled for the other defaults, but override this knob.
    skipHash = false

[interactive]
    diffFilter = ~/.local/bin/git-delta-diff-filter

[merge]
    conflictStyle = zdiff3

[diff]
    algorithm = histogram
    colorMoved = default
    colorMovedWS = allow-indentation-change

[delta]
    # Palette derived from bluz71/vim-nightfly-colors OpenCode diff colors.
    dark = true
    navigate = true
    side-by-side = true
    line-numbers = true
    syntax-theme = fly16

    # Diff surfaces.
    plus-style = syntax "#2a4e57"
    plus-non-emph-style = syntax "#2a4e57"
    plus-empty-line-marker-style = normal "#2a4e57"
    minus-style = syntax "#4e3030"
    minus-non-emph-style = syntax "#4e3030"
    minus-empty-line-marker-style = normal "#4e3030"

    # Headers and line numbers.
    file-style = bold "#82aaff"
    hunk-header-style = file line-number syntax "#092236"
    hunk-header-file-style = bold "#82aaff"
    hunk-header-line-number-style = "#7c8f8f"
    line-numbers-left-style = "#4b6479"
    line-numbers-right-style = "#4b6479"
    line-numbers-zero-style = "#4b6479"
    line-numbers-plus-style = "#21c7a8" "#2a4e57"
    line-numbers-minus-style = "#ff5874" "#4e3030"
    inline-hint-style = "#4b6479"

    # Delta-specific emphasis and whitespace errors.
    # Keep intraline edits on the same add/remove backgrounds to match upstream
    # Nightfly OpenCode highlight semantics. If they ever feel too subtle,
    # trial a Nightfly blue emphasis background before adding more green/red.
    plus-emph-style = bold "#21c7a8" "#2a4e57"
    minus-emph-style = bold "#ff5874" "#4e3030"
    whitespace-error-style = bold "#ff5874" "#4e3030"

[alias]
    # Convenience aliases for editing the supported Git config layers
    config-shared = "!git config --file ~/.config/git/config"
    config-local = "!git config --file ~/.gitconfig.local"
    
    # Squash commits into a single commit with custom message
    # Supports both count-based and hash-based targeting
    # 
    # Count-based (squashes last N commits):
    #   git squash -m "message" 3          # Squash last 3 commits
    # 
    # Hash-based (squashes from hash to HEAD):
    #   git squash -m "message" abc1234    # Squash from abc1234^ to HEAD (excludes abc1234)
    #   git squash -m "message" abc1234^   # Squash from abc1234 to HEAD (includes abc1234)
    #   git squash -m "message" HEAD~5     # Squash last 5 commits (alternative syntax)
    #   git squash -m "message" main       # Squash from main to HEAD
    squash = "!f() { \
        if echo \"$3\" | grep -q '^[0-9]\\+$'; then \
            git reset --soft HEAD~$3 && git commit -m \"$2\"; \
        elif git rev-parse --verify \"$3\" >/dev/null 2>&1; then \
            git reset --soft \"$3\" && git commit -m \"$2\"; \
        else \
            echo \"Error: Invalid commit hash or count: $3\"; \
            exit 1; \
        fi; \
    }; f" 

[advice]
    skippedCherryPicks = false

[rerere]
    enabled = true
    autoUpdate = true

[branch]
    autoSetupMerge = simple
    sort = -committerdate
