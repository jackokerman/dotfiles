{
  "document": {
    "block_prefix": "\n",
    "block_suffix": "\n",
    "color": "7",
    "margin": 2
  },
  "block_quote": {
    "color": "#a1aab8",
    "indent": 1,
    "indent_token": "| "
  },
  "paragraph": {},
  "list": {
    "color": "7",
    "level_indent": 2
  },
  "heading": {
    "block_suffix": "\n",
    "color": "4",
    "bold": false
  },
  "h1": {
    "prefix": "# ",
    "color": "4",
    "bold": false
  },
  "h2": {
    "prefix": "## ",
    "color": "4"
  },
  "h3": {
    "prefix": "### ",
    "color": "4"
  },
  "h4": {
    "prefix": "#### "
  },
  "h5": {
    "prefix": "##### "
  },
  "h6": {
    "prefix": "###### ",
    "color": "#a1aab8",
    "bold": false
  },
  "text": {},
  "strikethrough": {
    "crossed_out": true
  },
  "emph": {
    "italic": true
  },
  "strong": {
    "bold": true
  },
  "hr": {
    "color": "#38507a",
    "format": "\n--------\n"
  },
  "item": {
    "block_prefix": "- "
  },
  "enumeration": {
    "block_prefix": ". ",
    "color": "#82aaff"
  },
  "task": {
    "ticked": "[x] ",
    "unticked": "[ ] "
  },
  "link": {
    "color": "#87bcff",
    "underline": true
  },
  "link_text": {
    "color": "#7fdbca"
  },
  "image": {
    "color": "#87bcff",
    "underline": true
  },
  "image_text": {
    "color": "#7fdbca",
    "format": "Image: {{.text}} ->"
  },
  "code": {
    "prefix": "`",
    "suffix": "`",
    "color": "11"
  },
  "code_block": {
    "color": "#c0c0c0",
    "margin": 2,
    "chroma": {
      "text": {
        "color": "#c0c0c0"
      },
      "error": {
        "color": "#011627",
        "background_color": "#fc514e"
      },
      "comment": {
        "color": "#808080",
        "italic": true
      },
      "comment_preproc": {
        "color": "#808080",
        "italic": true
      },
      "keyword": {
        "color": "#800080"
      },
      "keyword_reserved": {
        "color": "#800080"
      },
      "keyword_namespace": {
        "color": "#800080"
      },
      "keyword_type": {
        "color": "#21c7a8"
      },
      "operator": {
        "color": "#800080"
      },
      "punctuation": {
        "color": "#c0c0c0"
      },
      "name": {
        "color": "#c0c0c0"
      },
      "name_builtin": {
        "color": "#000080"
      },
      "name_tag": {
        "color": "#000080"
      },
      "name_attribute": {
        "color": "#008080"
      },
      "name_class": {
        "color": "#21c7a8",
        "bold": false
      },
      "name_constant": {
        "color": "#808000"
      },
      "name_decorator": {
        "color": "#808000"
      },
      "name_exception": {},
      "name_function": {
        "color": "#000080"
      },
      "name_other": {},
      "literal": {},
      "literal_number": {
        "color": "#ae81ff"
      },
      "literal_date": {},
      "literal_string": {
        "color": "#808000"
      },
      "literal_string_escape": {
        "color": "#800000"
      },
      "generic_deleted": {
        "color": "#800000"
      },
      "generic_emph": {
        "italic": true
      },
      "generic_inserted": {
        "color": "#008000"
      },
      "generic_strong": {
        "bold": true
      },
      "generic_subheading": {
        "color": "#000080"
      },
      "background": {
        "background_color": "#011627"
      }
    }
  },
  "table": {},
  "definition_list": {},
  "definition_term": {},
  "definition_description": {
    "block_prefix": "\n> "
  },
  "html_block": {},
  "html_span": {}
}
