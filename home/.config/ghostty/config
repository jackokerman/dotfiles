# Ghostty Terminal Configuration

# Font configuration
font-family = MonoLisa Variable
font-family = Symbols Nerd Font Mono
font-size = 14
font-thicken = true

# Cursor
cursor-style = block
cursor-style-blink = false
shell-integration-features = false
# Keep Shift+Cmd+Click available for links when tmux mouse mode is on.
mouse-shift-capture = false
mouse-hide-while-typing = true

# Theme
theme = nightfly
# Ghostty already sends Shift+Enter natively. Reuse Cmd+Enter for the same
# CSI-u newline sequence so terminal apps like Codex don't hit fullscreen.
keybind = super+enter=text:\x1b[13;2u
