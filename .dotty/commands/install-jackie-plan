#!/usr/bin/env bash
set -euo pipefail

readonly JACKIE_PLAN_REPO_URL="${JACKIE_PLAN_REPO_URL:-https://github.com/jackokerman/jackie-plan.git}"
readonly JACKIE_PLAN_BRANCH="${JACKIE_PLAN_BRANCH:-main}"
readonly JACKIE_PLAN_SRC_ROOT="${JACKIE_PLAN_SRC_ROOT:-$HOME/src}"
readonly JACKIE_PLAN_REPO_DIR="${JACKIE_PLAN_REPO_DIR:-${JACKIE_PLAN_SRC_ROOT}/jackie-plan}"
readonly JACKIE_PLAN_COMPAT_REPO_DIR="${JACKIE_PLAN_COMPAT_REPO_DIR:-$HOME/.local/share/jackie-plan/repo}"

log() {
  printf '[jackie-plan] %s\n' "$*"
}

warn() {
  printf '[jackie-plan] warning: %s\n' "$*" >&2
}

git_no_prompt() {
  GIT_TERMINAL_PROMPT=0 git "$@"
}

if [[ ! -e "${JACKIE_PLAN_REPO_DIR}" ]]; then
  mkdir -p "$(dirname "${JACKIE_PLAN_REPO_DIR}")"
  if ! git_no_prompt clone --branch "${JACKIE_PLAN_BRANCH}" "${JACKIE_PLAN_REPO_URL}" "${JACKIE_PLAN_REPO_DIR}"; then
    warn "Skipping install because ${JACKIE_PLAN_REPO_URL} could not be cloned"
    exit 0
  fi
  log "Cloned Jackie Plan"
fi

if [[ -d "${JACKIE_PLAN_REPO_DIR}/.git" && ! -x "${JACKIE_PLAN_REPO_DIR}/scripts/install.sh" ]]; then
  git_no_prompt -C "${JACKIE_PLAN_REPO_DIR}" fetch origin "${JACKIE_PLAN_BRANCH}" >/dev/null 2>&1 || true
  git -C "${JACKIE_PLAN_REPO_DIR}" merge --ff-only "origin/${JACKIE_PLAN_BRANCH}" >/dev/null 2>&1 || true
fi

if [[ ! -x "${JACKIE_PLAN_REPO_DIR}/scripts/install.sh" ]]; then
  warn "Skipping install because ${JACKIE_PLAN_REPO_DIR}/scripts/install.sh is missing or not executable"
  exit 0
fi

if [[ ! -e "${JACKIE_PLAN_COMPAT_REPO_DIR}" ]]; then
  mkdir -p "$(dirname "${JACKIE_PLAN_COMPAT_REPO_DIR}")"
  ln -s "${JACKIE_PLAN_REPO_DIR}" "${JACKIE_PLAN_COMPAT_REPO_DIR}"
elif [[ -L "${JACKIE_PLAN_COMPAT_REPO_DIR}" && "$(readlink "${JACKIE_PLAN_COMPAT_REPO_DIR}")" == "${JACKIE_PLAN_REPO_DIR}" ]]; then
  :
elif [[ "${JACKIE_PLAN_COMPAT_REPO_DIR}" != "${JACKIE_PLAN_REPO_DIR}" ]]; then
  warn "Leaving existing ${JACKIE_PLAN_COMPAT_REPO_DIR} in place; ${JACKIE_PLAN_REPO_DIR} is the active checkout"
fi

"${JACKIE_PLAN_REPO_DIR}/scripts/install.sh" "$@"

for bin_dir in "$HOME/.local/bin" "$HOME/.dotty/bin"; do
  mkdir -p "${bin_dir}"
  for command_name in jp jackie-plan; do
    tmp_file="$(mktemp "${bin_dir}/.${command_name}.XXXXXX")"
    cat > "${tmp_file}" <<EOF
#!/usr/bin/env bash
set -euo pipefail

export BUN_INSTALL="\${BUN_INSTALL:-\$HOME/.bun}"
export PATH="\${BUN_INSTALL}/bin:\${PATH}"

if [[ -x "\${BUN_INSTALL}/bin/bun" ]]; then
  exec "\${BUN_INSTALL}/bin/bun" "${JACKIE_PLAN_REPO_DIR}/src/cli.ts" "\$@"
fi

exec bun "${JACKIE_PLAN_REPO_DIR}/src/cli.ts" "\$@"
EOF
    chmod 755 "${tmp_file}"
    mv "${tmp_file}" "${bin_dir}/${command_name}"
  done
done

log "Installed PATH-safe jp wrappers"
