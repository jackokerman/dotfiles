#!/usr/bin/env bash
set -euo pipefail

readonly GODSPEED_JS_REPO_DIR="${DOTTY_DEVTOOL_CHECKOUT_DIR:?DOTTY_DEVTOOL_CHECKOUT_DIR is required}"

info_log() {
  printf '[godspeed-js] %s\n' "$*"
}

warning_log() {
  printf '[godspeed-js] warning: %s\n' "$*" >&2
}

die() {
  printf '[godspeed-js] error: %s\n' "$*" >&2
  exit 1
}

if ! command -v bun >/dev/null 2>&1; then
  warning_log "Skipping install because Bun is not available"
  exit 0
fi

if [[ ! -f "${GODSPEED_JS_REPO_DIR}/package.json" ]]; then
  warning_log "Skipping install because ${GODSPEED_JS_REPO_DIR}/package.json is missing"
  exit 0
fi

info_log "Installing CLIs"
bun install --cwd "${GODSPEED_JS_REPO_DIR}" --frozen-lockfile --silent \
  || die "Failed to install dependencies"
bun run --cwd "${GODSPEED_JS_REPO_DIR}" install:local \
  || die "Failed to link CLIs"
