#!/usr/bin/env bash

set -euo pipefail

PROJECT_ROOT="$(git rev-parse --show-toplevel)"

log() {
    printf '[check] %s\n' "$*"
}

fail() {
    printf '[check] %s\n' "$*" >&2
    exit 1
}

run_bash_syntax() {
    local -a files=(
        ".dotty/run.sh"
        ".dotty/commands/brew-sync"
        ".dotty/commands/macos-setup"
        ".githooks/pre-commit"
        "home/.config/tmux/agent-status-hook.sh"
        "home/.config/tmux/agent-status/hook.sh"
        "home/.config/tmux/agent-status/lib.sh"
        "home/.config/tmux/agent-status/main.sh"
        "home/.config/tmux/agent-status/pane-state.sh"
        "home/.config/tmux/session-status.sh"
        "home/.local/bin/git-delta-diff-filter"
        "home/.local/bin/git-pager-delta"
        "home/.local/bin/sesh-pick"
        "home/.local/bin/sesh-one-shot"
        "home/.local/bin/tmux-link-test"
        "home/.raycast-scripts/arrange-windows.sh"
        "install.sh"
        "scripts/brew-sync.sh"
        "scripts/enable-touchid-sudo.sh"
        "scripts/check"
        "scripts/install-fonts.sh"
        "scripts/install-git-hooks.sh"
        "scripts/macos-setup.sh"
        "scripts/sync-handy-settings.sh"
        "scripts/macos.sh"
        "tests/handy/test-sync-handy-settings.sh"
        "tests/tmux-agent-status/test-overlay-contract.sh"
        "tests/tmux-agent-status/test-pane-state.sh"
        "tests/tmux-agent-status/test-session-status-local.sh"
        "tests/tmux-agent-status/test-session-status.sh"
        "tests/tmux-agent-status/testlib.sh"
        "scripts/validate-codex-sync.sh"
    )

    log "Checking bash syntax"
    (cd "$PROJECT_ROOT" && bash -n "${files[@]}")
}

assert_expected_executables() {
    local -a files=(
        ".dotty/run.sh"
        ".dotty/commands/brew-sync"
        ".dotty/commands/macos-setup"
        "install.sh"
        "scripts/brew-sync.sh"
        "scripts/check"
        "scripts/enable-touchid-sudo.sh"
        "scripts/install-fonts.sh"
        "scripts/install-git-hooks.sh"
        "scripts/macos-setup.sh"
        "scripts/sync-handy-settings.sh"
        "scripts/macos.sh"
    )
    local file

    log "Checking expected executable files"
    for file in "${files[@]}"; do
        [[ -x "$PROJECT_ROOT/$file" ]] || fail "expected executable bit on $file"
    done
}

run_zsh_syntax() {
    local -a files=(
        "home/.config/zsh/.aliases"
        "home/.config/zsh/.p10k.zsh"
        "home/.config/zsh/.zetch.zsh"
        "home/.config/zsh/.zshenv"
        "home/.config/zsh/.zshrc"
        "home/.config/zsh/sesh.zsh"
        "home/.zshenv"
    )

    log "Checking zsh syntax"
    (cd "$PROJECT_ROOT" && zsh -n "${files[@]}")
}

assert_zsh_runtime_inputs_removed() {
    local path

    log "Checking zsh source/runtime boundary"
    for path in \
        "home/.config/zsh/.zcompcache" \
        "home/.config/zsh/.zcompdump" \
        "home/.config/zsh/.zsh_history" \
        "home/.config/zsh/.zsh_sessions"; do
        [[ ! -e "$PROJECT_ROOT/$path" ]] || fail "unexpected zsh runtime path in repo: $path"
    done
}

assert_zsh_bootstrap_boundary() {
    local zshrc_path="$PROJECT_ROOT/home/.config/zsh/.zshrc"

    log "Checking zsh bootstrap boundary"

    if grep -q '_DOTFILES_ZSHRC_LOADED' "$zshrc_path"; then
        fail "tracked zshrc should not depend on real ~/.zshrc"
    fi

    if grep -Eq 'source[[:space:]]+("?)(~|\$HOME|\$\{HOME\})/\.zshrc\1([[:space:]]|$)' "$zshrc_path"; then
        fail "tracked zshrc should not source real ~/.zshrc"
    fi
}

run_tmux_agent_status_tests() {
    log "Running tmux agent status regression tests"
    "$PROJECT_ROOT/tests/tmux-agent-status/test-pane-state.sh"
    "$PROJECT_ROOT/tests/tmux-agent-status/test-session-status-local.sh"
    "$PROJECT_ROOT/tests/tmux-agent-status/test-session-status.sh"
    "$PROJECT_ROOT/tests/tmux-agent-status/test-overlay-contract.sh"
}

run_handy_tests() {
    log "Running Handy sync regression tests"
    "$PROJECT_ROOT/tests/handy/test-sync-handy-settings.sh"
}

run_godspeed_tasks_tests() {
    log "Running Godspeed task helper tests"
    bun test "$PROJECT_ROOT/tests/godspeed-tasks/godspeed-tasks.test.ts"
}

main() {
    run_bash_syntax
    run_zsh_syntax
    assert_expected_executables
    assert_zsh_runtime_inputs_removed
    assert_zsh_bootstrap_boundary
    run_tmux_agent_status_tests
    run_handy_tests
    run_godspeed_tasks_tests

    log "Validating Codex sync inputs"
    "$PROJECT_ROOT/scripts/validate-codex-sync.sh"
}

main "$@"
