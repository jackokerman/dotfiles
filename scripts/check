#!/usr/bin/env bash

set -euo pipefail

PROJECT_ROOT="$(git rev-parse --show-toplevel)"
CHECK_MODE="core"
CHECK_QUIET=0
STAGED_FILES=()

log() {
    printf '[check] %s\n' "$*"
}

fail() {
    printf '[check] %s\n' "$*" >&2
    exit 1
}

usage() {
    cat <<'EOF'
Usage: scripts/check [--core|--extended|--full|--staged] [--quiet]

  --core      Run the default core validation lane. This is the default.
  --extended  Run core checks plus helper and integration regressions.
  --full      Alias for --extended.
  --staged    Run common checks plus tests for staged path groups.
  --quiet     Print one summary line per successful phase and full output only on failure.
EOF
}

parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --core)
                CHECK_MODE="core"
                ;;
            --extended)
                CHECK_MODE="extended"
                ;;
            --full)
                CHECK_MODE="extended"
                ;;
            --staged|--pre-commit)
                CHECK_MODE="staged"
                ;;
            --quiet)
                CHECK_QUIET=1
                ;;
            -h|--help)
                usage
                exit 0
                ;;
            *)
                fail "unknown argument: $1"
                ;;
        esac
        shift
    done
}

print_advisory_lines() {
    local output_file="$1"

    awk '
        /0 errors, 0 warnings/ { next }
        /long paragraph|warning|warnings|error|errors|suggestion|suggestions/ { print }
    ' "$output_file"
}

run_phase() {
    local label="$1"
    local advisory="${2:-0}"
    local output_file=""
    local exit_code=0

    shift 2

    if [[ "$CHECK_QUIET" -eq 0 ]]; then
        "$@"
        return
    fi

    output_file="$(mktemp "${TMPDIR:-/tmp}/dotfiles-check.XXXXXX")"
    set +e
    ( set -euo pipefail; "$@" ) >"$output_file" 2>&1
    exit_code=$?
    set -e

    if [[ "$exit_code" -eq 0 ]]; then
        printf '[check] ok: %s\n' "$label"
        if [[ "$advisory" -eq 1 ]]; then
            print_advisory_lines "$output_file"
        fi
        rm -f "$output_file"
        return
    fi

    printf '[check] failed: %s\n' "$label" >&2
    cat "$output_file" >&2
    rm -f "$output_file"
    return "$exit_code"
}

load_staged_files() {
    local file

    STAGED_FILES=()
    while IFS= read -r file; do
        [[ -n "$file" ]] || continue
        STAGED_FILES+=("$file")
    done < <(git -C "$PROJECT_ROOT" diff --cached --name-only --diff-filter=ACMRT)
}

changed_any() {
    local file pattern

    for file in "${STAGED_FILES[@]+"${STAGED_FILES[@]}"}"; do
        for pattern in "$@"; do
            case "$file" in
                $pattern)
                    return 0
                    ;;
            esac
        done
    done

    return 1
}

run_bash_syntax() {
    local -a files=(
        ".dotty/run.sh"
        ".dotty/commands/brew-sync"
        ".dotty/commands/install-jackie-plan"
        ".dotty/commands/install-nvim-js-tools"
        ".dotty/commands/macos-setup"
        ".dotty/commands/sync-dev-checkouts"
        ".dotty/commands/sync-tmux-agent-bar"
        ".githooks/pre-commit"
        "home/.config/tmux/agent-status-hook.sh"
        "home/.config/tmux/codex-agent-status-hook.sh"
        "home/.config/tmux/session-status-left.sh"
        "home/.config/tmux/session-status-refresh.sh"
        "home/.config/tmux/session-status.sh"
        "home/.config/tmux/tmux-agent-bar-path.sh"
        "home/.local/bin/git-delta-diff-filter"
        "home/.local/bin/git-pager-delta"
        "home/.local/bin/codex-session-snippets"
        "home/.local/bin/plugin-eval"
        "home/.local/bin/slack-rich-text"
        "home/.local/bin/sesh-pick"
        "home/.local/bin/sesh-one-shot"
        "home/.local/bin/tmux-link-test"
        "home/.raycast-scripts/arrange-windows.sh"
        "home/.raycast-scripts/copy-markdown-as-slack-rich-text.sh"
        "home/.raycast-scripts/paste-markdown-as-slack-rich-text.sh"
        "install.sh"
        "scripts/brew-sync.sh"
        "tests/brew-sync/test-brewfile-gh-provider.sh"
        "tests/brew-sync/test-brew-sync.sh"
        "scripts/enable-touchid-sudo.sh"
        "scripts/install-fzf.sh"
        "scripts/install-nvim-js-tools.sh"
        "scripts/check"
        "scripts/check-prose.sh"
        "scripts/sync-dev-checkouts.sh"
        "scripts/install-fonts.sh"
        "scripts/install-git-hooks.sh"
        "scripts/macos-setup.sh"
        "scripts/sync-tmux-agent-bar.sh"
        "scripts/sync-handy-settings.sh"
        "scripts/macos.sh"
        "tests/brew-sync/test-brew-sync.sh"
        "tests/sesh/test-setup.sh"
        "tests/television/test-setup.sh"
        "tests/tmux-agent-bar/test-runtime-path.sh"
        "tests/tmux-agent-bar/test-session-status-left.sh"
        "tests/tmux-agent-bar/test-sync.sh"
        "tests/tmux-agent-status/testlib.sh"
        "scripts/validate-codex-sync.sh"
    )

    log "Checking bash syntax"
    (cd "$PROJECT_ROOT" && bash -n "${files[@]}")
}

assert_expected_executables() {
    local -a files=(
        ".dotty/run.sh"
        ".dotty/commands/brew-sync"
        ".dotty/commands/install-jackie-plan"
        ".dotty/commands/install-nvim-js-tools"
        ".dotty/commands/macos-setup"
        ".dotty/commands/sync-dev-checkouts"
        ".dotty/commands/sync-tmux-agent-bar"
        "install.sh"
        "scripts/brew-sync.sh"
        "scripts/check"
        "scripts/check-prose.sh"
        "scripts/sync-dev-checkouts.sh"
        "scripts/enable-touchid-sudo.sh"
        "scripts/install-fzf.sh"
        "scripts/install-nvim-js-tools.sh"
        "scripts/install-fonts.sh"
        "scripts/install-git-hooks.sh"
        "scripts/macos-setup.sh"
        "scripts/sync-tmux-agent-bar.sh"
        "scripts/sync-handy-settings.sh"
        "scripts/macos.sh"
        "home/.local/bin/slack-rich-text"
        "home/.local/bin/codex-session-snippets"
        "home/.local/bin/plugin-eval"
        "home/.config/tmux/codex-agent-status-hook.sh"
        "home/.config/tmux/session-status-left.sh"
        "home/.config/tmux/session-status-refresh.sh"
        "tests/dev-checkouts/test-sync.sh"
        "tests/television/test-setup.sh"
    )
    local file

    log "Checking expected executable files"
    for file in "${files[@]}"; do
        [[ -x "$PROJECT_ROOT/$file" ]] || fail "expected executable bit on $file"
    done
}

run_zsh_syntax() {
    local -a files=(
        "home/.config/zsh/.aliases"
        "home/.config/zsh/.p10k.zsh"
        "home/.config/zsh/.zetch.zsh"
        "home/.config/zsh/.zshenv"
        "home/.config/zsh/.zshrc"
        "home/.config/zsh/sesh.zsh"
        "home/.zshenv"
    )

    log "Checking zsh syntax"
    (cd "$PROJECT_ROOT" && zsh -n "${files[@]}")
}

assert_zsh_runtime_inputs_removed() {
    local path

    log "Checking zsh source/runtime boundary"
    for path in \
        "home/.config/zsh/.zcompcache" \
        "home/.config/zsh/.zcompdump" \
        "home/.config/zsh/.zsh_history" \
        "home/.config/zsh/.zsh_sessions"; do
        [[ ! -e "$PROJECT_ROOT/$path" ]] || fail "unexpected zsh runtime path in repo: $path"
    done
}

assert_zsh_bootstrap_boundary() {
    local zshrc_path="$PROJECT_ROOT/home/.config/zsh/.zshrc"

    log "Checking zsh bootstrap boundary"

    if grep -q '_DOTFILES_ZSHRC_LOADED' "$zshrc_path"; then
        fail "tracked zshrc should not depend on real ~/.zshrc"
    fi

    if grep -Eq 'source[[:space:]]+("?)(~|\$HOME|\$\{HOME\})/\.zshrc\1([[:space:]]|$)' "$zshrc_path"; then
        fail "tracked zshrc should not source real ~/.zshrc"
    fi
}

assert_git_local_overrides_last() {
    local git_config_path="$PROJECT_ROOT/home/.config/git/config"
    local github_helper_line=""
    local local_include_line=""

    log "Checking Git local override order"

    github_helper_line=$(awk '
        $0 == "[credential \"https://github.com\"]" { in_github = 1; next }
        /^\[/ { in_github = 0 }
        in_github && $0 ~ /helper[[:space:]]*=[[:space:]]*!gh auth git-credential/ { print NR; exit }
    ' "$git_config_path")

    local_include_line=$(awk '
        $0 == "[include]" { in_include = 1; next }
        /^\[/ { in_include = 0 }
        in_include && $0 ~ /path[[:space:]]*=[[:space:]]*~\/\.gitconfig\.local/ { print NR; exit }
    ' "$git_config_path")

    [[ -n "$github_helper_line" ]] || fail "missing github.com gh credential helper in $git_config_path"
    [[ -n "$local_include_line" ]] || fail "missing ~/.gitconfig.local include in $git_config_path"
    [[ "$local_include_line" -gt "$github_helper_line" ]] || fail "~/.gitconfig.local include must come after shared github.com credential helpers"
}

run_tmux_agent_bar_tests() {
    log "Running tmux-agent-bar runtime path and sync tests"
    "$PROJECT_ROOT/tests/tmux-agent-bar/test-runtime-path.sh"
    "$PROJECT_ROOT/tests/tmux-agent-bar/test-session-status-left.sh"
    "$PROJECT_ROOT/tests/tmux-agent-bar/test-sync.sh"
}

run_brew_sync_tests() {
    log "Running brew-sync regression tests"
    "$PROJECT_ROOT/tests/brew-sync/test-brewfile-gh-provider.sh"
    "$PROJECT_ROOT/tests/brew-sync/test-brew-sync.sh"
}

run_dev_checkout_tests() {
    log "Running development checkout sync tests"
    "$PROJECT_ROOT/tests/dev-checkouts/test-sync.sh"
}

run_sesh_tests() {
    log "Running sesh setup regression tests"
    "$PROJECT_ROOT/tests/sesh/test-setup.sh"
}

run_television_tests() {
    log "Running Television regression tests"
    "$PROJECT_ROOT/tests/television/test-setup.sh"
}

run_karabiner_config_tests() {
    log "Running Karabiner config regression tests"
    bun --install=auto test "$PROJECT_ROOT/tests/karabiner/karabiner-config.test.ts"
}

run_codex_sync_tests() {
    log "Running Codex sync regression tests"
    bun test "$PROJECT_ROOT/tests/codex/sync-codex.test.ts"
    bun test "$PROJECT_ROOT/tests/codex/sync-ruler.test.ts"
}

run_codex_config_coach_tests() {
    log "Running Codex config coach helper tests"
    bun test "$PROJECT_ROOT/tests/codex-config-coach/codex-session-snippets.test.ts"
}

run_slack_rich_text_tests() {
    log "Running Slack rich-text helper tests"
    bun --install=auto test "$PROJECT_ROOT/tests/slack-rich-text/slack-rich-text.test.ts"
}

run_codex_theme_sync_check() {
    log "Checking Codex Nightfly theme generation"
    bun --install=auto "$PROJECT_ROOT/scripts/ts/sync-codex-nightfly-theme.ts" --check
}

run_common_checks() {
    run_phase "bash syntax" 0 run_bash_syntax
    run_phase "zsh syntax" 0 run_zsh_syntax
    run_phase "expected executable files" 0 assert_expected_executables
    run_phase "zsh source/runtime boundary" 0 assert_zsh_runtime_inputs_removed
    run_phase "zsh bootstrap boundary" 0 assert_zsh_bootstrap_boundary
    run_phase "Git local override order" 0 assert_git_local_overrides_last
}

run_prose_checks() {
    log "Running advisory prose checks"
    "$PROJECT_ROOT/scripts/check-prose.sh" --advisory
}

run_codex_sync_validation() {
    log "Validating Codex sync inputs"
    "$PROJECT_ROOT/scripts/validate-codex-sync.sh"
}

run_full_checks() {
    run_extended_checks
}

run_core_checks() {
    run_common_checks
    run_phase "Codex sync regression tests" 0 run_codex_sync_tests
    run_phase "Codex Nightfly theme generation" 0 run_codex_theme_sync_check
    run_phase "Codex sync input validation" 0 run_codex_sync_validation
    run_phase "brew-sync regression tests" 0 run_brew_sync_tests
    run_phase "advisory prose checks" 1 run_prose_checks
}

run_extended_checks() {
    run_core_checks
    run_phase "tmux-agent-bar runtime path and sync tests" 0 run_tmux_agent_bar_tests
    run_phase "development checkout sync tests" 0 run_dev_checkout_tests
    run_phase "sesh setup regression tests" 0 run_sesh_tests
    run_phase "Television regression tests" 0 run_television_tests
    run_phase "Karabiner config regression tests" 0 run_karabiner_config_tests
    run_phase "Codex config coach helper tests" 0 run_codex_config_coach_tests
    run_phase "Slack rich-text helper tests" 0 run_slack_rich_text_tests
}

run_staged_checks() {
    load_staged_files

    if [[ ${#STAGED_FILES[@]} -eq 0 ]]; then
        log "No staged files; running common checks only"
        run_common_checks
        return
    fi

    if changed_any "scripts/check" ".githooks/pre-commit"; then
        log "Check runner changed; running extended suite"
        run_extended_checks
        return
    fi

    run_common_checks

    if changed_any \
        ".dotty/commands/sync-tmux-agent-bar" \
        "home/.config/tmux/*" \
        "scripts/sync-tmux-agent-bar.sh" \
        "tests/tmux-agent-bar/*" \
        "tests/tmux-agent-status/*"; then
        run_phase "tmux-agent-bar runtime path and sync tests" 0 run_tmux_agent_bar_tests
    fi

    if changed_any ".dotty/commands/brew-sync" "Brewfile" "scripts/brew-sync.sh" "tests/brew-sync/*"; then
        run_phase "brew-sync regression tests" 0 run_brew_sync_tests
    fi

    if changed_any \
        ".dotty/dev-checkouts.tsv" \
        ".dotty/commands/sync-dev-checkouts" \
        ".dotty/run.sh" \
        "scripts/sync-dev-checkouts.sh" \
        "tests/dev-checkouts/*"; then
        run_phase "development checkout sync tests" 0 run_dev_checkout_tests
    fi

    if changed_any \
        ".dotty/config" \
        ".dotty/run.sh" \
        "home/.config/sesh/sesh.toml" \
        "home/.config/zsh/sesh.zsh" \
        "tests/sesh/*"; then
        run_phase "sesh setup regression tests" 0 run_sesh_tests
    fi

    if changed_any \
        ".dotty/config" \
        ".dotty/run.sh" \
        "home/.config/television/*" \
        "home/.config/television/themes/*" \
        "tests/television/*"; then
        run_phase "Television regression tests" 0 run_television_tests
    fi

    if changed_any "scripts/ts/karabiner-config.ts" "tests/karabiner/*"; then
        run_phase "Karabiner config regression tests" 0 run_karabiner_config_tests
    fi

    if changed_any "home/.codex/*" "home/.ruler/*" "scripts/ts/sync-codex-*" "scripts/ts/sync-ruler.ts" "scripts/validate-codex-sync.sh" "tests/codex/*"; then
        run_phase "Codex sync regression tests" 0 run_codex_sync_tests
        run_phase "Codex sync input validation" 0 run_codex_sync_validation
    fi

    if changed_any "home/.codex/skills/codex-config-coach/*" "home/.local/lib/codex-session-snippets.ts" "tests/codex-config-coach/*"; then
        run_phase "Codex config coach helper tests" 0 run_codex_config_coach_tests
    fi

    if changed_any "home/.local/bin/slack-rich-text" "home/.local/lib/slack-rich-text.ts" "home/.raycast-scripts/*slack-rich-text*" "tests/slack-rich-text/*"; then
        run_phase "Slack rich-text helper tests" 0 run_slack_rich_text_tests
    fi

    if changed_any "scripts/ts/sync-codex-nightfly-theme.ts" "home/.codex/references/nightfly/*"; then
        run_phase "Codex Nightfly theme generation" 0 run_codex_theme_sync_check
    fi

    if changed_any "README.md" "docs/*.md" "scripts/check-prose.sh"; then
        run_phase "advisory prose checks" 1 run_prose_checks
    fi
}

main() {
    parse_args "$@"

    case "$CHECK_MODE" in
        core)
            run_core_checks
            ;;
        extended)
            run_extended_checks
            ;;
        staged)
            run_staged_checks
            ;;
        *)
            fail "unknown check mode: $CHECK_MODE"
            ;;
    esac
}

main "$@"
