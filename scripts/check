#!/usr/bin/env bash

set -euo pipefail

PROJECT_ROOT="$(git rev-parse --show-toplevel)"
CHECK_MODE="full"
STAGED_FILES=()

log() {
    printf '[check] %s\n' "$*"
}

fail() {
    printf '[check] %s\n' "$*" >&2
    exit 1
}

usage() {
    cat <<'EOF'
Usage: scripts/check [--full|--staged]

  --full     Run the complete local regression suite. This is the default.
  --staged   Run cheap checks plus tests for staged path groups.
EOF
}

parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --full)
                CHECK_MODE="full"
                ;;
            --staged|--pre-commit)
                CHECK_MODE="staged"
                ;;
            -h|--help)
                usage
                exit 0
                ;;
            *)
                fail "unknown argument: $1"
                ;;
        esac
        shift
    done
}

load_staged_files() {
    local file

    STAGED_FILES=()
    while IFS= read -r file; do
        [[ -n "$file" ]] || continue
        STAGED_FILES+=("$file")
    done < <(git -C "$PROJECT_ROOT" diff --cached --name-only --diff-filter=ACMRT)
}

changed_any() {
    local file pattern

    for file in "${STAGED_FILES[@]+"${STAGED_FILES[@]}"}"; do
        for pattern in "$@"; do
            case "$file" in
                $pattern)
                    return 0
                    ;;
            esac
        done
    done

    return 1
}

run_bash_syntax() {
    local -a files=(
        ".dotty/run.sh"
        ".dotty/commands/brew-sync"
        ".dotty/commands/install-nvim-js-tools"
        ".dotty/commands/macos-setup"
        ".dotty/commands/sync-tmux-agent-bar"
        ".githooks/pre-commit"
        "home/.config/tmux/agent-status-hook.sh"
        "home/.config/tmux/codex-agent-status-hook.sh"
        "home/.config/tmux/session-status-left.sh"
        "home/.config/tmux/session-status-refresh.sh"
        "home/.config/tmux/session-status.sh"
        "home/.config/tmux/tmux-agent-bar-path.sh"
        "home/.local/bin/git-delta-diff-filter"
        "home/.local/bin/git-pager-delta"
        "home/.local/bin/codex-session-snippets"
        "home/.local/bin/plugin-eval"
        "home/.local/bin/public-content-guard"
        "home/.local/bin/slack-rich-text"
        "home/.local/bin/sesh-pick"
        "home/.local/bin/sesh-one-shot"
        "home/.local/bin/tmux-link-test"
        "home/.raycast-scripts/arrange-windows.sh"
        "home/.raycast-scripts/copy-markdown-as-slack-rich-text.sh"
        "home/.raycast-scripts/paste-markdown-as-slack-rich-text.sh"
        "install.sh"
        "scripts/brew-sync.sh"
        "scripts/enable-touchid-sudo.sh"
        "scripts/install-nvim-js-tools.sh"
        "scripts/check"
        "scripts/check-prose.sh"
        "scripts/install-fonts.sh"
        "scripts/install-git-hooks.sh"
        "scripts/macos-setup.sh"
        "scripts/sync-tmux-agent-bar.sh"
        "scripts/sync-handy-settings.sh"
        "scripts/macos.sh"
        "tests/handy/test-sync-handy-settings.sh"
        "tests/sesh/test-setup.sh"
        "tests/tmux-agent-bar/test-runtime-path.sh"
        "tests/tmux-agent-bar/test-sync.sh"
        "tests/tmux-agent-bar/test-wrappers.sh"
        "tests/tuicr/test-setup.sh"
        "tests/public-content-guard/test-guard.sh"
        "tests/zsh/test-p10k-overrides.sh"
        "tests/tmux-agent-status/testlib.sh"
        "scripts/validate-codex-sync.sh"
    )

    log "Checking bash syntax"
    (cd "$PROJECT_ROOT" && bash -n "${files[@]}")
}

assert_expected_executables() {
    local -a files=(
        ".dotty/run.sh"
        ".dotty/commands/brew-sync"
        ".dotty/commands/install-nvim-js-tools"
        ".dotty/commands/macos-setup"
        ".dotty/commands/sync-tmux-agent-bar"
        "install.sh"
        "scripts/brew-sync.sh"
        "scripts/check"
        "scripts/check-prose.sh"
        "scripts/enable-touchid-sudo.sh"
        "scripts/install-nvim-js-tools.sh"
        "scripts/install-fonts.sh"
        "scripts/install-git-hooks.sh"
        "scripts/macos-setup.sh"
        "scripts/sync-tmux-agent-bar.sh"
        "scripts/sync-handy-settings.sh"
        "scripts/macos.sh"
        "home/.local/bin/slack-rich-text"
        "home/.local/bin/codex-session-snippets"
        "home/.local/bin/plugin-eval"
        "home/.local/bin/public-content-guard"
        "home/.config/tmux/codex-agent-status-hook.sh"
        "home/.config/tmux/session-status-left.sh"
        "home/.config/tmux/session-status-refresh.sh"
        "tests/tuicr/test-setup.sh"
    )
    local file

    log "Checking expected executable files"
    for file in "${files[@]}"; do
        [[ -x "$PROJECT_ROOT/$file" ]] || fail "expected executable bit on $file"
    done
}

run_zsh_syntax() {
    local -a files=(
        "home/.config/zsh/.aliases"
        "home/.config/zsh/.p10k.zsh"
        "home/.config/zsh/.zetch.zsh"
        "home/.config/zsh/.zshenv"
        "home/.config/zsh/.zshrc"
        "home/.config/zsh/sesh.zsh"
        "home/.zshenv"
    )

    log "Checking zsh syntax"
    (cd "$PROJECT_ROOT" && zsh -n "${files[@]}")
}

assert_zsh_runtime_inputs_removed() {
    local path

    log "Checking zsh source/runtime boundary"
    for path in \
        "home/.config/zsh/.zcompcache" \
        "home/.config/zsh/.zcompdump" \
        "home/.config/zsh/.zsh_history" \
        "home/.config/zsh/.zsh_sessions"; do
        [[ ! -e "$PROJECT_ROOT/$path" ]] || fail "unexpected zsh runtime path in repo: $path"
    done
}

assert_zsh_bootstrap_boundary() {
    local zshrc_path="$PROJECT_ROOT/home/.config/zsh/.zshrc"

    log "Checking zsh bootstrap boundary"

    if grep -q '_DOTFILES_ZSHRC_LOADED' "$zshrc_path"; then
        fail "tracked zshrc should not depend on real ~/.zshrc"
    fi

    if grep -Eq 'source[[:space:]]+("?)(~|\$HOME|\$\{HOME\})/\.zshrc\1([[:space:]]|$)' "$zshrc_path"; then
        fail "tracked zshrc should not source real ~/.zshrc"
    fi
}

run_tmux_agent_bar_tests() {
    log "Running tmux-agent-bar wrapper and sync tests"
    "$PROJECT_ROOT/tests/tmux-agent-bar/test-runtime-path.sh"
    "$PROJECT_ROOT/tests/tmux-agent-bar/test-wrappers.sh"
    "$PROJECT_ROOT/tests/tmux-agent-bar/test-sync.sh"
}

run_handy_tests() {
    log "Running Handy sync regression tests"
    "$PROJECT_ROOT/tests/handy/test-sync-handy-settings.sh"
}

run_tuicr_tests() {
    log "Running tuicr runtime checkout tests"
    "$PROJECT_ROOT/tests/tuicr/test-setup.sh"
}

run_sesh_tests() {
    log "Running sesh regression tests"
    "$PROJECT_ROOT/tests/sesh/test-setup.sh"
    "$PROJECT_ROOT/tests/sesh/test-pick.sh"
}

run_zsh_prompt_tests() {
    log "Running zsh prompt regression tests"
    bash "$PROJECT_ROOT/tests/zsh/test-p10k-overrides.sh"
}

run_godspeed_tasks_tests() {
    log "Running Godspeed task helper tests"
    bun test "$PROJECT_ROOT/tests/godspeed-tasks/godspeed-tasks.test.ts"
}

run_karabiner_config_tests() {
    log "Running Karabiner config regression tests"
    bun --install=auto test "$PROJECT_ROOT/tests/karabiner/karabiner-config.test.ts"
}

run_codex_sync_tests() {
    log "Running Codex sync regression tests"
    bun test "$PROJECT_ROOT/tests/codex/sync-codex.test.ts"
    bun test "$PROJECT_ROOT/tests/codex/sync-ruler.test.ts"
}

run_codex_config_coach_tests() {
    log "Running Codex config coach helper tests"
    bun test "$PROJECT_ROOT/tests/codex-config-coach/codex-session-snippets.test.ts"
}

run_slack_rich_text_tests() {
    log "Running Slack rich-text helper tests"
    bun --install=auto test "$PROJECT_ROOT/tests/slack-rich-text/slack-rich-text.test.ts"
}

run_public_content_guard_tests() {
    log "Running public content guard tests"
    "$PROJECT_ROOT/tests/public-content-guard/test-guard.sh"
}

run_codex_theme_sync_check() {
    log "Checking Codex Nightfly theme generation"
    bun --install=auto "$PROJECT_ROOT/scripts/ts/sync-codex-nightfly-theme.ts" --check
}

run_common_checks() {
    run_bash_syntax
    run_zsh_syntax
    assert_expected_executables
    assert_zsh_runtime_inputs_removed
    assert_zsh_bootstrap_boundary
}

run_prose_checks() {
    log "Running advisory prose checks"
    "$PROJECT_ROOT/scripts/check-prose.sh" --advisory
}

run_codex_sync_validation() {
    log "Validating Codex sync inputs"
    "$PROJECT_ROOT/scripts/validate-codex-sync.sh"
}

run_full_checks() {
    run_common_checks
    run_tmux_agent_bar_tests
    run_handy_tests
    run_tuicr_tests
    run_sesh_tests
    run_zsh_prompt_tests
    run_godspeed_tasks_tests
    run_karabiner_config_tests
    run_codex_sync_tests
    run_codex_config_coach_tests
    run_slack_rich_text_tests
    run_public_content_guard_tests
    run_codex_theme_sync_check
    run_codex_sync_validation
    run_prose_checks
}

run_staged_checks() {
    load_staged_files

    if [[ ${#STAGED_FILES[@]} -eq 0 ]]; then
        log "No staged files; running common checks only"
        run_common_checks
        return
    fi

    if changed_any "scripts/check" ".githooks/pre-commit"; then
        log "Check runner changed; running full suite"
        run_full_checks
        return
    fi

    run_common_checks

    if changed_any \
        ".dotty/commands/sync-tmux-agent-bar" \
        "home/.config/tmux/*" \
        "scripts/sync-tmux-agent-bar.sh" \
        "tests/tmux-agent-bar/*" \
        "tests/tmux-agent-status/*"; then
        run_tmux_agent_bar_tests
    fi

    if changed_any "scripts/sync-handy-settings.sh" "tests/handy/*"; then
        run_handy_tests
    fi

    if changed_any ".dotty/run.sh" "tests/tuicr/*"; then
        run_tuicr_tests
    fi

    if changed_any \
        ".dotty/config" \
        ".dotty/run.sh" \
        "home/.config/sesh/sesh.toml" \
        "home/.local/bin/sesh-pick" \
        "home/.local/bin/sesh-one-shot" \
        "home/.config/zsh/sesh.zsh" \
        "tests/sesh/*"; then
        run_sesh_tests
    fi

    if changed_any "home/.config/zsh/*" "home/.zshenv" "tests/zsh/*"; then
        run_zsh_prompt_tests
    fi

    if changed_any "home/.ruler/skills/godspeed-tasks/*" "tests/godspeed-tasks/*"; then
        run_godspeed_tasks_tests
    fi

    if changed_any "scripts/ts/karabiner-config.ts" "tests/karabiner/*"; then
        run_karabiner_config_tests
    fi

    if changed_any "home/.codex/*" "home/.ruler/*" "scripts/ts/sync-codex-*" "scripts/ts/sync-ruler.ts" "scripts/validate-codex-sync.sh" "tests/codex/*"; then
        run_codex_sync_tests
        run_codex_sync_validation
    fi

    if changed_any "home/.codex/skills/codex-config-coach/*" "home/.local/lib/codex-session-snippets.ts" "tests/codex-config-coach/*"; then
        run_codex_config_coach_tests
    fi

    if changed_any "home/.local/bin/slack-rich-text" "home/.local/lib/slack-rich-text.ts" "home/.raycast-scripts/*slack-rich-text*" "tests/slack-rich-text/*"; then
        run_slack_rich_text_tests
    fi

    if changed_any "home/.local/bin/public-content-guard" "scripts/check-sensitive-content.sh" "tests/public-content-guard/*"; then
        run_public_content_guard_tests
    fi

    if changed_any "scripts/ts/sync-codex-nightfly-theme.ts" "home/.codex/references/nightfly/*"; then
        run_codex_theme_sync_check
    fi

    if changed_any "README.md" "docs/*.md" ".vale.ini" ".vale/*" "scripts/check-prose.sh"; then
        run_prose_checks
    fi
}

main() {
    parse_args "$@"

    case "$CHECK_MODE" in
        full)
            run_full_checks
            ;;
        staged)
            run_staged_checks
            ;;
        *)
            fail "unknown check mode: $CHECK_MODE"
            ;;
    esac
}

main "$@"
