#!/usr/bin/env bash

set -euo pipefail

PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

log() {
    printf '[sync-machine] %s\n' "$*"
}

usage() {
    cat <<'EOF'
Usage: ./scripts/sync-machine [--cleanup-casks]

Sync dotty-managed config and Brewfile packages for this repo.
On a fresh machine, falls back to ./install.sh.

Options:
  --cleanup-casks  Remove Homebrew casks that are not present in Brewfile.
  -h, --help       Show this help text.
EOF
}

dotty_cmd() {
    if command -v dotty >/dev/null 2>&1; then
        dotty "$@"
        return
    fi

    if [[ -x "$HOME/.dotty/bin/dotty" ]]; then
        "$HOME/.dotty/bin/dotty" "$@"
        return
    fi

    return 127
}

cleanup_casks=0

while (($#)); do
    case "$1" in
        --cleanup-casks)
            cleanup_casks=1
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            printf '[sync-machine] unknown argument: %s\n' "$1" >&2
            usage >&2
            exit 1
            ;;
    esac
    shift
done

if dotty_cmd status 2>/dev/null | grep -Fq "$PROJECT_ROOT"; then
    log "Updating the dotty chain and applying Brewfile changes"
    (
        cd "$PROJECT_ROOT"
        DOTFILES_RUN_BREW=1 dotty_cmd update
    )
else
    log "Repo is not installed with dotty yet; bootstrapping via install.sh"
    "$PROJECT_ROOT/install.sh"
fi

if (( cleanup_casks )); then
    if command -v brew >/dev/null 2>&1; then
        log "Removing Homebrew casks not present in Brewfile"
        brew bundle cleanup --file "$PROJECT_ROOT/Brewfile" --cask --force
    else
        log "Homebrew not found after sync; skipping cask cleanup"
    fi
fi

log "Open a new shell or run: exec zsh"
